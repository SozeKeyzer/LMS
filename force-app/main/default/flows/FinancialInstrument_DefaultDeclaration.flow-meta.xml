<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <description>When Is_In_Default__c flips to TRUE on a Financial Instrument: logs an audit event.</description>
    <environments>Default</environments>
    <interviewLabel>Financial Instrument Default Declaration {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Financial Instrument Default Declaration</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value><stringValue>LightningFlowBuilder</stringValue></value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>

    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Is_In_Default__c</field>
            <operator>IsChanged</operator>
            <value><booleanValue>true</booleanValue></value>
        </filters>
        <filters>
            <field>Is_In_Default__c</field>
            <operator>EqualTo</operator>
            <value><booleanValue>true</booleanValue></value>
        </filters>
        <object>Financial_Instrument__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <connector><targetReference>Log_Default_Declaration</targetReference></connector>
    </start>

    <actionCalls>
        <name>Log_Default_Declaration</name>
        <label>Log Default Declaration Audit Event</label>
        <locationX>176</locationX>
        <locationY>120</locationY>
        <actionName>AuditEventLogger</actionName>
        <actionType>apex</actionType>
        <inputParameters>
            <name>eventType</name>
            <value><stringValue>STATUS_CHANGED</stringValue></value>
        </inputParameters>
        <inputParameters>
            <name>objectApiName</name>
            <value><stringValue>Financial_Instrument__c</stringValue></value>
        </inputParameters>
        <inputParameters>
            <name>recordId</name>
            <value><elementReference>$Record.Id</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>source</name>
            <value><stringValue>Manual_Entry</stringValue></value>
        </inputParameters>
        <inputParameters>
            <name>reason</name>
            <value><stringValue>DEFAULT DECLARED - Financial Instrument placed in default. Formal cure process required before Matured or Closed status can be set.</stringValue></value>
        </inputParameters>
    </actionCalls>

</Flow>
